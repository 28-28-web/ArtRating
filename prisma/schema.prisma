generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  role                  String                 @default("user")
  createdAt             DateTime               @default(now())
  generations           Generation[]
  credit                UserCredit?
  creditPurchaseRequests CreditPurchaseRequest[]
}

model AnonymousUsage {
  id        String   @id // signed random id stored in an httpOnly cookie
  count     Int      @default(0)
  createdAt DateTime @default(now())
}

model Generation {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  anonId        String? // set when userId is null, links back to AnonymousUsage
  toolId        String // 'art-style' | 'headshot' | 'pet-to-human' | 'toy-ification' | 'photo-mix'
  usedCredit    Boolean   @default(false)
  status        String    @default("pending")
  imageUrl      String? // watermarked preview, shown on screen before payment
  cleanImageUrl String? // watermark-free file, only ever returned by /api/download.
  // Only ever set for generations made while logged in (userId != null) — see
  // the "option (b)" note in the download route: anonymous-era generations
  // aren't retroactively downloadable after logging in, so there's no clean
  // file to store for them and this column stays null.
  downloadedAt  DateTime? // set once the download credit has been charged, so a
  // page refresh / repeat click doesn't charge a second credit for the same file.
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([anonId])
}

model UserCredit {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id])
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model CreditPurchaseRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  method        String // 'bkash' | 'nagad'
  transactionRef String
  credits       Int
  status        String    @default("pending") // 'pending' | 'approved' | 'rejected'
  adminNote     String?
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?

  @@index([userId])
  @@index([status])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  category  String // 'general' | 'bug' | 'misuse-report' | 'business'
  message   String   @db.Text
  createdAt DateTime @default(now())
  resolved  Boolean  @default(false)

  @@index([resolved])
}

// Separate, much stricter cap for photo-mix only — flux-2-dev costs
// roughly 8,000-9,000 Neurons per call vs ~43 for the schnell-based tools,
// so 1-2 photo-mix generations can exhaust the whole account's 10,000/day
// free Neuron pool (shared across all 5 tools). Deliberately not part of
// AnonymousUsage/the shared 6-cap system — this is an independent, stricter
// limit that exists only because of this one tool's cost, not a subset of
// the shared quota.
model PhotoMixDailyUsage {
  id          String @id @default(cuid())
  identityKey String // anonId or userId, whichever applies
  // Plain "YYYY-MM-DD" (UTC) text, not a DateTime/@db.Date column — this was
  // a DateTime originally; switched after the 2nd-generation-not-blocked
  // investigation didn't turn up a confirmed code bug (see the commit that
  // made this change for what was checked and ruled out) but a Date object
  // round-tripping through JS -> Prisma -> Postgres DATE -> JS is one more
  // layer than this needs. A literal date string removes that layer
  // entirely — pure string equality, nothing to serialize or misinterpret,
  // and it's human-readable directly in the database or logs.
  usageDate String
  count     Int    @default(0)

  @@unique([identityKey, usageDate])
}
